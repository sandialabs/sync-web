(let* ((n 20000)
       (xs (let loop ((i 0) (acc '()))
             (if (= i n) acc (loop (+ i 1) (cons i acc)))))
       (ys (map (lambda (x) (+ (* x 3) 1)) xs)))
  (let loop ((rest ys) (acc 0) (count 0))
    (if (null? rest)
        (list acc count)
        (let ((x (car rest)))
          (if (= (modulo x 7) 0)
              (loop (cdr rest) (+ acc x) (+ count 1))
              (loop (cdr rest) acc count))))))
