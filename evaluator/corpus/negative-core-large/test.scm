(define (capture thunk)
  (catch #t thunk (lambda args (list 'caught (car args) (length args)))))

(define negative-results
  (list
    (capture (lambda () (car 1)))
    (capture (lambda () (cdr '())))
    (capture (lambda () (set-car! '() 1)))
    (capture (lambda () (vector-ref #(1 2) 9)))
    (capture (lambda () (vector-set! #(1 2) -1 0)))
    (capture (lambda () (substring "abc" 2 10)))
    (capture (lambda () (byte-vector-ref #u(1 2) 5)))
    (capture (lambda () (/ 1 0)))
    (capture (lambda () (+ 1 'x)))
    (capture (lambda () (apply + 1)))
    (capture (lambda () ((lambda (x) x))))
    (capture (lambda () ((lambda (x) x) 1 2)))
    (capture (lambda () (let ((x 1)) y)))
    (capture (lambda () (eval '(if))))
    (capture (lambda () (eval '(quote a b))))
    (capture (lambda () (eval '(set! missing 1))))
    (capture (lambda () (hash-table-ref (hash-table) 'missing)))
    (capture (lambda () (let-ref (inlet) 'missing)))
    (capture (lambda () (read (open-input-string "#("))))
    (capture (lambda () (read (open-input-string "\"unterminated"))))
    (capture (lambda () (read (open-input-string "#\\bad-character-name"))))
    (capture (lambda () (open-input-string 123)))
    (capture (lambda () (format #f "~D" 'not-number)))))

(list (length negative-results) negative-results)
