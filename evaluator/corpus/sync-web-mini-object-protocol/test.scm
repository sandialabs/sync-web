(define (make-counter name initial)
  (let ((value initial)
        (history '()))
    (lambda (msg . args)
      (case msg
        ((*type*) 'counter)
        ((name) name)
        ((get) value)
        ((history) (reverse history))
        ((set!) (set! value (car args))
                (set! history (cons (list 'set! value) history))
                value)
        ((inc!) (let ((amount (if (null? args) 1 (car args))))
                  (set! value (+ value amount))
                  (set! history (cons (list 'inc! amount value) history))
                  value))
        (else (error 'object-error "unknown message: ~S" msg))))))

(let ((c (make-counter 'visits 10)))
  (list
    (c '*type*)
    (c 'name)
    (c 'inc!)
    (c 'inc! 5)
    (c 'set! 3)
    (c 'history)))
