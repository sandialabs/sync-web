(let ((h (make-hash-table)))
  (do ((i 0 (+ i 1)))
      ((= i 200))
    (let ((v (vector i (* i i) (modulo i 11))))
      (hash-table-set! h i v)))
  (let loop ((i 0) (sum 0) (samples '()))
    (if (= i 200)
        (list sum (reverse samples) (hash-table? h))
        (let ((v (hash-table-ref h i)))
          (loop (+ i 1)
                (+ sum (v 1))
                (if (= (modulo i 50) 0) (cons v samples) samples))))))
