(lambda (run-test make-messenger general-src control-src standard-src chain-src tree-src config-src ledger-src)
  (let* ((pass (lambda (x) (append "pass-" (symbol->string x))))
         (general-src (let recurse ((src general-src))
                        (cond ((or (not (list? src)) (null? src)) src)
                              ((equal? (car src) 'sync-call)
                               (append `(sync-call ,(cadr src) #t) (cdddr src)))
                              ((list? (car src))
                               (cons (recurse (car src)) (recurse (cdr src))))
                              (else (cons (car src) (recurse (cdr src)))))))
         (install (lambda (x) `(,x (,general-src #t ,(pass x) ,(pass x) 1024 ,control-src ',standard-src ',chain-src ',tree-src ',config-src ',ledger-src) "Installed general interface")))
         (update (lambda (x) `(,x (*eval* ,(pass x) (,general-src #f ,(pass x) ,(pass x) 512 ,control-src ',standard-src ',chain-src ',tree-src ',config-src ',ledger-src)) "Installed general interface")))
         (interface-auth (lambda (journal secret payload test)
                           `(,journal ,(cons `(authentication ,secret) payload) ,test)))
         (interface (lambda (x) (interface-auth (car x) (pass (car x)) (cadr x) (if (null? (cddr x)) #t (caddr x))))))
    (run-test
     (append
      (map install '(journal))
      (map interface
           `((journal ((function size)) 0)
             (journal ((function *step!*)) 1)
             (journal ((function information)) (lambda (x) (list? x)))
             (journal ((function configuration) (arguments ((path (public window))))) 1024)
             (journal ((function get) (arguments ((path ((*state*)))))) '(directory ((*time* value)) #t))
             (journal ((function set!) (arguments ((path ((*state* hello))) (value "world")))) #t)
             (journal ((function get) (arguments ((path ((*state* hello)))))) "world")
             (journal ((function *step!*)) 2)
             (journal ((function synchronize) (arguments ((index 0)))) (lambda (x) (list? x)))
             (journal ((function batch!) (arguments ((queries (((function size))))))) '(2))
             (journal ((function resolve) (arguments ((path (-1 (*state* hello))) (pinned? #f) (proof? #f)))) "world")
             (journal ((function trace) (arguments ((index 0) (path (-1 (*state* hello)))))) (lambda (x) (list? x)))
             (journal ((function pin!) (arguments ((path (-1 (*state* hello)))))) #t)
             (journal ((function resolve) (arguments ((path (-1 (*state* hello))) (pinned? #t)))) '((content "world") (pinned? #t)))
             (journal ((function unpin!) (arguments ((path (-1 (*state* hello)))))) #t)
             (journal ((function bridge!) (arguments ((name gibberish) (interface "unimplemented-for-test"))))
                      (lambda (x) (eq? (car x) 'error)))
             (journal ((function *secret*) (arguments ((secret ,(pass 'journal)))) #t))))
      (map update '(journal))
      (map interface
           `((journal ((function size)) 2)
             (journal ((function *step!*)) 2)
             (journal ((function information)) (lambda (x) (list? x)))
             (journal ((function configuration) (arguments ((path (public window))))) 512)
             (journal ((function get) (arguments ((path ((*state*)))))) '(directory ((hello value) (*time* value)) #t))
             (journal ((function set!) (arguments ((path ((*state* hello))) (value "world")))) #t) ;
             (journal ((function get) (arguments ((path ((*state* hello)))))) "world")
             (journal ((function *step!*)) 2)
             (journal ((function synchronize) (arguments ((index 0)))) (lambda (x) (list? x)))
             (journal ((function batch!) (arguments ((queries (((function size))))))) '(2))
             (journal ((function resolve) (arguments ((path (-1 (*state* hello))) (pinned? #f) (proof? #f)))) "world")
             (journal ((function trace) (arguments ((index 0) (path (-1 (*state* hello)))))) (lambda (x) (list? x)))
             (journal ((function pin!) (arguments ((path (-1 (*state* hello)))))) #t)
             (journal ((function unpin!) (arguments ((path (-1 (*state* hello)))))) #t)
             (journal ((function bridge!) (arguments ((name gibberish) (interface "unimplemented-for-test"))))
                      (lambda (x) (eq? (car x) 'error)))
             (journal ((function *secret*) (arguments ((secret ,(pass 'journal)))) #t))))))))
