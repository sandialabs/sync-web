# Required: root/interface secret for the local ledger journal.
SECRET=change-me

# Optional stack isolation. Use distinct values for public/dev stacks.
COMPOSE_PROJECT_NAME=sync-ledger-dev

# Direct journal HTTP port. The raw interface is at /interface.
JOURNAL_PORT=8194

# Ledger settings.
PERIOD=2
WINDOW=1024
INTERFACE_ADMINS=admin

# Optional public identity advertised in bridge info. Defaults to SECRET when unset.
# INTERFACE=http://localhost:8194/interface
# JOURNAL_NAME=local-ledger

# Bridge policy advertised by info.
BRIDGE_PUBLISH=push
BRIDGE_SUBSCRIBE=pull

# Set to 1 to reinstall/update records against an existing database.
# JOURNAL_UPDATE=1
