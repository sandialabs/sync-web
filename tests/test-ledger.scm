             (journal-1 ((ledger 'get) '(8 (*bridge* journal-2 chain) -1 (*state* a b c))) 44)
             (journal-1 ((ledger 'get) '(8 (*bridge* journal-2 chain) -6 (*state* a b c))) 42)
             (journal-1 ((ledger 'update-config!) '(public public-key) #u(0)) #t)
             (journal-1 ((ledger 'update-config!) '(private secret-key) #u(1)) #t)
             (journal-1 ((ledger 'update-config!) '(public window) 2) #t)
