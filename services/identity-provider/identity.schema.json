{
  "$id": "https://sync-web.local/schemas/identity.username.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Person",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "title": "Username",
          "minLength": 3,
          "maxLength": 32,
          "pattern": "^[a-zA-Z0-9_\\-]+$",
          "ory.sh/kratos": {
            "credentials": { "password": { "identifier": true } }
          }
        }
      },
      "required": ["username"],
      "additionalProperties": false
    }
  }
}
