{
  "name": "synchronic-gateway",
  "version": "1.1.0",
  "private": true,
  "description": "Web-facing API gateway for the Synchronic Web general API.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:ui && npm run build:server",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "npm --prefix ui run build",
    "start": "node dist/server.js",
    "typecheck": "npm run typecheck:server && npm run typecheck:ui",
    "typecheck:server": "tsc --noEmit -p tsconfig.json",
    "typecheck:ui": "npm --prefix ui run typecheck",
    "test": "npm run test:server && npm run test:ui",
    "test:server": "node --test --import tsx test/*.test.ts",
    "test:ui": "npm --prefix ui test"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@ory/client-fetch": "^1.22.37",
    "fastify": "^5.6.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
