{
  "name": "synchronic-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Web-facing API gateway for the Synchronic Web general interface.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx test/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
